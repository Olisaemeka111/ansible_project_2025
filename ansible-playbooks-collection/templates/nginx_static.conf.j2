# Nginx configuration for static site
server {
    listen {{ listen_port | default(80) }};
    server_name {{ server_name | default('_') }};
    root {{ document_root | default('/var/www/html') }};
    index index.html index.htm;

    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_comp_level 6;
    gzip_types
        text/plain
        text/css
        application/json
        application/javascript
        text/xml
        application/xml
        text/javascript
        image/svg+xml
        application/x-font-ttf
        font/opentype;

    location / {
        try_files $uri $uri/ =404;
    }

    # Cache static assets aggressively
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|otf)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # Cache HTML for a short time
    location ~* \.html$ {
        expires 1h;
        add_header Cache-Control "public, must-revalidate";
    }

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;

    # Deny hidden files
    location ~ /\. {
        deny all;
    }

    access_log /var/log/nginx/{{ server_name | default('static') }}_access.log;
    error_log /var/log/nginx/{{ server_name | default('static') }}_error.log;
}

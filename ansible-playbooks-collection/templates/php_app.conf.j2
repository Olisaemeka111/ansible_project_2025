; PHP-FPM Pool Configuration for {{ app_name }}
; Generated by Ansible

[{{ app_name }}]

; Process user/group
user = {{ app_user | default('www-data') }}
group = {{ app_group | default('www-data') }}

; Listen on Unix socket (faster than TCP)
listen = /run/php/php{{ php_version | default('8.2') }}-fpm-{{ app_name }}.sock
listen.owner = www-data
listen.group = www-data
listen.mode = 0660

; Process manager settings
pm = {{ pm_type | default('dynamic') }}
pm.max_children = {{ pm_max_children | default(50) }}
pm.start_servers = {{ pm_start_servers | default(5) }}
pm.min_spare_servers = {{ pm_min_spare | default(5) }}
pm.max_spare_servers = {{ pm_max_spare | default(35) }}
pm.max_requests = {{ pm_max_requests | default(500) }}

; Timeouts
request_terminate_timeout = {{ request_timeout | default(300) }}
request_slowlog_timeout = {{ slowlog_timeout | default(10) }}

; Logging
access.log = /var/log/php-fpm/{{ app_name }}_access.log
slowlog = /var/log/php-fpm/{{ app_name }}_slow.log

; Error handling
php_flag[display_errors] = off
php_admin_flag[log_errors] = on
php_admin_value[error_log] = /var/log/php-fpm/{{ app_name }}_error.log

; Resource limits
php_admin_value[memory_limit] = {{ memory_limit | default('256M') }}
php_admin_value[upload_max_filesize] = {{ upload_max | default('64M') }}
php_admin_value[post_max_size] = {{ post_max | default('64M') }}
php_admin_value[max_execution_time] = {{ max_execution_time | default(300) }}

; Security
php_admin_value[open_basedir] = {{ app_dir | default('/var/www/' + app_name) }}:/tmp
php_admin_value[disable_functions] = exec,passthru,shell_exec,system,proc_open,popen

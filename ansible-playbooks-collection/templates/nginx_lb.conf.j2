# Ansible managed - Nginx load balancer configuration
# Template: nginx_lb.conf.j2
#
# Variables:
#   app_name         - Application name used for upstream block naming
#   backend_servers  - List of backend server addresses (e.g., ['10.0.1.10:8080', '10.0.1.11:8080'])
#   lb_port          - Load balancer listen port (default: 80)
#   server_name      - Server hostname (default: '_')
#   lb_method        - Load balancing method: round_robin, least_conn, ip_hash (default: round_robin)
#   enable_ssl       - Enable SSL termination (default: false)
#   ssl_cert         - Path to SSL certificate
#   ssl_key          - Path to SSL private key
#   proxy_connect_timeout - Upstream connect timeout (default: 60s)
#   proxy_read_timeout    - Upstream read timeout (default: 60s)

# Upstream backend pool for {{ app_name }}
upstream {{ app_name }}_backend {
{% if lb_method | default('round_robin') == 'least_conn' %}
    # Use least connections algorithm - sends requests to server with fewest active connections
    least_conn;
{% elif lb_method | default('round_robin') == 'ip_hash' %}
    # Use IP hash - ensures client always reaches the same backend (session persistence)
    ip_hash;
{% endif %}

{% for server in backend_servers %}
    server {{ server }}{% if server_weight is defined and server_weight[loop.index0] is defined %} weight={{ server_weight[loop.index0] }}{% endif %};
{% endfor %}

    # Keep connections alive to backends for better performance
    keepalive {{ keepalive_connections | default(32) }};
}

server {
    listen {{ lb_port | default(80) }};
    server_name {{ server_name | default('_') }};

    # Proxy timeouts
    proxy_connect_timeout {{ proxy_connect_timeout | default('60s') }};
    proxy_send_timeout {{ proxy_send_timeout | default('60s') }};
    proxy_read_timeout {{ proxy_read_timeout | default('60s') }};

    # Buffer settings
    proxy_buffering on;
    proxy_buffer_size 4k;
    proxy_buffers 8 4k;

    location / {
        proxy_pass http://{{ app_name }}_backend;

        # Pass original client information to backends
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Enable keepalive to upstream
        proxy_http_version 1.1;
        proxy_set_header Connection "";
    }

{% if health_check_path is defined %}
    # Health check endpoint (proxied to backends)
    location {{ health_check_path }} {
        proxy_pass http://{{ app_name }}_backend;
        proxy_set_header Host $host;
        access_log off;
    }
{% endif %}

    # Logging
    access_log /var/log/nginx/{{ app_name }}_lb_access.log;
    error_log /var/log/nginx/{{ app_name }}_lb_error.log;
}

{% if enable_ssl | default(false) %}
# SSL termination server block
server {
    listen 443 ssl http2;
    server_name {{ server_name | default('_') }};

    ssl_certificate {{ ssl_cert }};
    ssl_certificate_key {{ ssl_key }};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;

    proxy_connect_timeout {{ proxy_connect_timeout | default('60s') }};
    proxy_send_timeout {{ proxy_send_timeout | default('60s') }};
    proxy_read_timeout {{ proxy_read_timeout | default('60s') }};

    location / {
        proxy_pass http://{{ app_name }}_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
    }

    access_log /var/log/nginx/{{ app_name }}_lb_ssl_access.log;
    error_log /var/log/nginx/{{ app_name }}_lb_ssl_error.log;
}

# HTTP to HTTPS redirect
server {
    listen {{ lb_port | default(80) }};
    server_name {{ server_name | default('_') }};
    return 301 https://$host$request_uri;
}
{% endif %}

# Docker Compose configuration - generated by Ansible
# Application: {{ app_name }}

services:
{% for service in compose_services %}
  {{ service.name }}:
    image: {{ service.image | default(service.name + ':' + image_tag) }}
{% if service.build is defined %}
    build:
      context: {{ service.build.context | default('.') }}
      dockerfile: {{ service.build.dockerfile | default('Dockerfile') }}
{% endif %}
{% if service.container_name is defined %}
    container_name: {{ service.container_name }}
{% endif %}
{% if service.ports is defined %}
    ports:
{% for port in service.ports %}
      - "{{ port }}"
{% endfor %}
{% endif %}
{% if service.environment is defined %}
    environment:
{% for key, value in service.environment.items() %}
      {{ key }}: "{{ value }}"
{% endfor %}
{% endif %}
{% if service.env_file is defined %}
    env_file:
      - {{ service.env_file }}
{% endif %}
{% if service.volumes is defined %}
    volumes:
{% for volume in service.volumes %}
      - {{ volume }}
{% endfor %}
{% endif %}
{% if service.depends_on is defined %}
    depends_on:
{% for dep in service.depends_on %}
      - {{ dep }}
{% endfor %}
{% endif %}
{% if service.command is defined %}
    command: {{ service.command }}
{% endif %}
{% if service.healthcheck is defined %}
    healthcheck:
      test: {{ service.healthcheck.test }}
      interval: {{ service.healthcheck.interval | default('30s') }}
      timeout: {{ service.healthcheck.timeout | default('10s') }}
      retries: {{ service.healthcheck.retries | default(3) }}
{% endif %}
    restart: {{ service.restart | default('unless-stopped') }}
{% if not loop.last %}

{% endif %}
{% endfor %}

{% if compose_volumes is defined %}
volumes:
{% for vol in compose_volumes %}
  {{ vol.name }}:
    driver: {{ vol.driver | default('local') }}
{% endfor %}
{% endif %}

{% if compose_networks is defined %}
networks:
{% for net in compose_networks %}
  {{ net.name }}:
    driver: {{ net.driver | default('bridge') }}
{% endfor %}
{% endif %}

# OpenVPN Server Configuration
# Generated by Ansible

# Network
port {{ vpn_port | default(1194) }}
proto {{ vpn_protocol | default('udp') }}
dev tun

# Certificates and keys
ca /etc/openvpn/server/ca.crt
cert /etc/openvpn/server/server.crt
key /etc/openvpn/server/server.key
dh /etc/openvpn/server/dh.pem
tls-auth /etc/openvpn/server/ta.key 0

# VPN subnet
server {{ vpn_network | default('10.8.0.0') }} {{ vpn_netmask | default('255.255.255.0') }}

# Maintain a record of client virtual IP address associations
ifconfig-pool-persist /var/log/openvpn/ipp.txt

# Push routes to clients
{% if vpn_push_routes is defined %}
{% for route in vpn_push_routes %}
push "route {{ route }}"
{% endfor %}
{% endif %}

# Push DNS to clients
{% if vpn_dns_servers is defined %}
{% for dns in vpn_dns_servers %}
push "dhcp-option DNS {{ dns }}"
{% endfor %}
{% else %}
push "dhcp-option DNS 8.8.8.8"
push "dhcp-option DNS 8.8.4.4"
{% endif %}

# Redirect all traffic through VPN (optional)
{% if vpn_redirect_gateway | default(false) %}
push "redirect-gateway def1 bypass-dhcp"
{% endif %}

# Allow clients to see each other
{% if vpn_client_to_client | default(false) %}
client-to-client
{% endif %}

# Keepalive
keepalive 10 120

# Encryption
cipher AES-256-GCM
auth SHA256
tls-version-min 1.2

# Reduce daemon privileges after init
user nobody
group nogroup

# Persist options across restarts
persist-key
persist-tun

# Logging
status /var/log/openvpn/openvpn-status.log
log-append /var/log/openvpn/openvpn.log
verb {{ vpn_verbosity | default(3) }}

# Max clients
max-clients {{ vpn_max_clients | default(100) }}

# Compression (disabled for security)
;compress lz4-v2
;push "compress lz4-v2"
